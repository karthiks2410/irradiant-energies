# --- Quote form: transactional email via Resend ---
# Without these, /api/quote still works — it falls back to the WhatsApp deep-link
# and returns { ok: true, emailDelivered: false }.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender on your Resend domain (irradiantenergie.com).
# This is intentionally a no-reply address — replies bounce, which is the point.
# All real follow-ups happen on WhatsApp / phone / in person.
EMAIL_FROM=do-not-reply@irradiantenergie.com

# Internal sales inbox that receives lead-alert emails
LEAD_EMAIL=leads@irradiantenergie.com

# Resend webhook signing secret — set after registering the webhook at
# https://resend.com/webhooks pointing to /api/resend-webhook.
# Subscribe ONLY to email.bounced + email.complained (high signal,
# low volume). Without this, /api/resend-webhook returns 401.
RESEND_WEBHOOK_SECRET=
